<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.strategist.scout</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{IWE_RUNTIME}}/roles/strategist/scripts/strategist.sh</string>
        <string>scout</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>4</integer>
        <key>Minute</key>
        <integer>5</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>{{HOME_DIR}}/logs/strategist/launchd-scout.log</string>

    <key>StandardErrorPath</key>
    <string>{{HOME_DIR}}/logs/strategist/launchd-scout-error.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>HOME</key>
        <string>{{HOME_DIR}}</string>
        <key>IWE_TEMPLATE</key>
        <string>{{IWE_TEMPLATE}}</string>
        <key>IWE_WORKSPACE</key>
        <string>{{WORKSPACE_DIR}}</string>
        <key>IWE_RUNTIME</key>
        <string>{{IWE_RUNTIME}}</string>
        <key>IWE_GOVERNANCE_REPO</key>
        <string>{{GOVERNANCE_REPO}}</string>
    </dict>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
